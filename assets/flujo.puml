@startuml
title Diagrama de Flujo Completo - Sistema de Gestión y Despacho de Pedidos

skinparam shadowing false
skinparam activity {
  BackgroundColor white
  BorderColor black
  ArrowColor black
}

start

partition "Administrador" {
  :Iniciar registro del pedido;
  :Autenticarse en el sistema;
}

partition "Sistema" {
  :Consultar Staff;
  :Consultar Role del empleado;
  if (¿Role = Administrador?) then (Sí)
  else (No)
    :Acceso denegado;
    stop
  endif

  :Buscar Customer por teléfono o email;
  if (¿Customer existe?) then (Sí)
    :Cargar datos del cliente;
  else (No)
    :Registrar Customer;
  endif

  :Consultar Product disponibles;
}

partition "Administrador" {
  repeat
    :Seleccionar producto;
    :Ingresar cantidad;
  repeat while (¿Agregar otro producto?) is (Sí)
}

partition "Sistema" {
  :Crear CustomerOrder;
  :Crear OrderItem por cada producto seleccionado;
  :Calcular total_amount;
  :Consultar OrderStatus = "Pendiente";
  :Asignar current_status_id en CustomerOrder;
  :Registrar OrderStatusHistory\n(Inicio -> Pendiente);
}

partition "Cliente" {
  :Ingresar código del pedido para consultar;
}

partition "Sistema" {
  :Buscar CustomerOrder por order_code;
  :Mostrar estado actual desde OrderStatus;
  :Mostrar historial desde OrderStatusHistory;
}

partition "Cocinero" {
  :Autenticarse en el sistema;
}

partition "Sistema" {
  :Consultar Staff;
  :Consultar Role del empleado;
  if (¿Role = Cocinero?) then (Sí)
  else (No)
    :Acceso denegado;
    stop
  endif

  :Listar CustomerOrder con estado "Pendiente";
}

partition "Cocinero" {
  :Tomar pedido para preparación;
}

partition "Sistema" {
  :Consultar OrderStatus = "En preparación";
  :Actualizar CustomerOrder.current_status_id;
  :Registrar OrderStatusHistory\n(Pendiente -> En preparación);
}

partition "Cocinero" {
  :Preparar pedido;
  :Registrar finalización;
}

partition "Sistema" {
  :Consultar OrderStatus = "Listo para entrega";
  :Actualizar CustomerOrder.current_status_id;
  :Registrar OrderStatusHistory\n(En preparación -> Listo para entrega);
}

partition "Repartidor" {
  :Autenticarse en el sistema;
}

partition "Sistema" {
  :Consultar Staff;
  :Consultar Role del empleado;
  if (¿Role = Repartidor?) then (Sí)
  else (No)
    :Acceso denegado;
    stop
  endif

  :Listar CustomerOrder con estado "Listo para entrega";
}

partition "Repartidor" {
  :Aceptar pedido para despacho;
}

partition "Sistema" {
  :Crear Delivery;
  :Asignar courier_staff_id;
  :Registrar dispatched_at;
  :Consultar OrderStatus = "En camino";
  :Actualizar CustomerOrder.current_status_id;
  :Registrar OrderStatusHistory\n(Listo para entrega -> En camino);
}

partition "Cliente" {
  :Consultar nuevamente el pedido;
}

partition "Sistema" {
  :Buscar CustomerOrder por order_code;
  :Mostrar estado actual = "En camino";
  :Mostrar historial actualizado;
}

partition "Repartidor" {
  :Entregar pedido;
  :Registrar nombre de quien recibe;
  :Confirmar entrega;
}

partition "Sistema" {
  :Validar estado actual del pedido;
  if (¿CustomerOrder está en "En camino"?) then (Sí)
    :Actualizar Delivery.delivered_at;
    :Actualizar Delivery.receiver_name;
    :Consultar OrderStatus = "Entregado";
    :Actualizar CustomerOrder.current_status_id;
    :Registrar OrderStatusHistory\n(En camino -> Entregado);
    :Confirmar entrega exitosa;
  else (No)
    :Rechazar entrega por regla de negocio;
  endif
}

partition "Cliente" {
  :Consultar estado final del pedido;
}

partition "Sistema" {
  :Buscar CustomerOrder por order_code;
  :Mostrar estado actual desde OrderStatus;
  :Mostrar historial completo desde OrderStatusHistory;
}

stop

legend right
= Entidades usadas en el flujo

1. Role
Se usa para validar el rol del empleado.

2. Staff
Se usa para identificar al Administrador, Cocinero y Repartidor.

3. Customer
Se consulta o registra al cliente antes de crear el pedido.

4. Product
Se consulta para seleccionar los productos del pedido.

5. CustomerOrder
Representa el pedido principal.

6. OrderItem
Guarda cada producto y cantidad del pedido.

7. OrderStatus
Se consulta en cada cambio de estado del pedido.

8. OrderStatusHistory
Registra todos los cambios de estado.

9. Delivery
Registra la salida y entrega del pedido.
end legend

@enduml
